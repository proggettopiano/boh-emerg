Subject: [PATCH 2/2] fix: change FormData field from 'files' to 'file'

Backend deployed on Render expects 'file' (singular), not 'files' (plural).
This matches the 422 error: loc: ['body', 'file']

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 frontend/src/components/UploadModal.jsx | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/frontend/src/components/UploadModal.jsx b/frontend/src/components/UploadModal.jsx
index e16c4e0..c739568 100644
--- a/frontend/src/components/UploadModal.jsx
+++ b/frontend/src/components/UploadModal.jsx
@@ -113,7 +113,7 @@ export default function UploadModal({ open, onClose, onComplete, libraryId }) {
     try {
       const formData = new FormData();
       files.forEach(({ file }) => {
-        formData.append("files", file);
+        formData.append("file", file);
       });
 
       const completed = await api.post("/pdfs/upload", formData, {
