# ScoreLib backend configuration
APP_NAME=ScoreLib

# Required database settings
MONGO_URL=mongodb://localhost:27017
DB_NAME=scorelib

# Authentication
JWT_SECRET=change-me-with-a-long-random-secret
ADMIN_EMAIL=admin@scorelib.app

# CORS: comma-separated frontend origins allowed to call the API
BACKEND_CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
# Optional regex for Vercel preview deployments
BACKEND_CORS_ORIGIN_REGEX=^https://scorelib(-.*)?\.vercel\.app$

# Upload limits and worker controls
MAX_UPLOAD_SIZE_BYTES=52428800
UPLOAD_SESSION_TTL_SECONDS=3600
WORKER_SECRET=change-me-if-you-call-worker-endpoints

# Optional Google OAuth / Drive integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional transactional email through Resend
RESEND_API_KEY=
FROM_EMAIL=ScoreLib <noreply@scorelib.app>
SENDER_EMAIL=noreply@scorelib.app
